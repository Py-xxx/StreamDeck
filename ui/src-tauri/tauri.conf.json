{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Deckling",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "fs": {
        "readFile": true,
        "writeFile": true,
        "createDir": true,
        "exists": true,
        "scope": ["$HOME/.deckling", "$HOME/.deckling/**", "$HOME\\.deckling", "$HOME\\.deckling\\**"]
      },
      "path": { "all": true }
    },
    "bundle": {
      "active": true,
      "identifier": "com.deckling.controller",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.ico"
      ]
    },
    "security": { "csp": null },
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "label": "main",
        "title": "Deckling",
        "width": 640,
        "height": 760,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "fileDropEnabled": false
      }
    ]
  }
}
